---
import PrincipalTitle from "./PrincipalTitle.astro";
import HeroDescription from "./HeroDescription.astro";
import ProfilePhoto from "./ProfilePhoto.astro";
---

<section
   class="relative min-h-[85vh] flex items-center bg-bg-base overflow-hidden"
>
   <div
      class="container mx-auto flex flex-col md:flex-row items-center justify-between z-10"
   >
      <div class="w-full md:w-[40rem] order-1 md:order-1">
         <PrincipalTitle />
         <HeroDescription />

         <div class="flex items-center gap-10">
            <a
               href="/catalogo"
               class="bg-cta text-cta-text px-8 py-4 rounded-full font-body font-medium sm:text-lg text-sm hover:bg-title-primary transition-all duration-500"
            >
               Explorar catálogo
            </a>

            <a
               href="#proceso"
               class="group flex items-center gap-2 text-sm uppercase tracking-[0.3em] text-title-primary/70 font-medium"
            >
               proceso
            </a>
         </div>
      </div>

      <ProfilePhoto/>
   </div>
</section>

<style>
   /* Animación más lenta y sutil (8s) para mayor elegancia */
   @keyframes nido-slow {
      0%,
      100% {
         transform: translate(0, 0) rotate(0deg);
      }
      50% {
         transform: translate(-10px, -12px) rotate(2deg);
      }
   }
   .animate-nido-slow {
      animation: nido-slow 10s ease-in-out infinite;
   }
</style>
