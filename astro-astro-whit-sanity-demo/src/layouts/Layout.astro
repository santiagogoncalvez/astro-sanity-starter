      <style is:global>
         /* Personalizar si hay modo oscuro y claro */
         :root {
            color-scheme: light;
         }

         @font-face {
            font-family: "General Sans Variable";
            src:
               url("/GeneralSans-Variable.woff2") format("woff2-variations"),
               url("/GeneralSans-Variable.woff2") format("woff2");
            font-weight: 200 700;
            font-display: swap;
            font-style: normal;
         }

         @font-face {
            font-family: "Geist";
            src:
               url("/Geist-Variable.ttf") format("truetype-variations"),
               url("/Geist-Variable.ttf") format("truetype");
            font-weight: 100 900;
            font-display: swap;
            font-style: normal;
         }

         /* Personalizar fuente de cuerpo */
         html {
            font-family:
               "Geist",
               system-ui,
               -apple-system,
               BlinkMacSystemFont,
               sans-serif;
            scroll-behavior: smooth;
         }

         body {
            margin: 0;
            min-height: 100vh;
         }

         @media (prefers-reduced-motion: reduce) {
            html {
               scroll-behavior: auto;
            }
         }
      </style>

      <slot name="head" />

      <meta name="generator" content={Astro.generator} />

      <link rel="canonical" href={urlPage} />

