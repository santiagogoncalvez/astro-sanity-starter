---
import { sanityClient } from "sanity:client";
import Layout from "@layouts/Layout.astro";
import SectionContainer from "@components/shared/SectionContainer.astro";
import { slugify } from "@utils/slugify"; // Asegúrate de crear este archivo
import Like from "@/icons/Like.astro";

const PRODUCTS_QUERY = `*[_type == "product"] | order(_createdAt desc) {
  _id, 
  title, 
  price, 
  category,
  "imageUrl": mainImage.asset->url
}`;

const products = await sanityClient.fetch(PRODUCTS_QUERY);

// Agregamos el slug dinámico a cada producto
const productsWithSlug = products.map((product: any) => ({
   ...product,
   generatedSlug: slugify(product.title),
}));
---

<Layout
   title="Catálogo | nidotrama"
   description="Nuestros productos artesanales tejidos a mano."
>
   <main class="w-full pt-25 xl:pt-24 flex flex-col justify-center">
      <SectionContainer class="xl:px-12 md:px-8 px-6 pb-16 md:pb-24">
         <h1
            class="font-title font-[750] text-5xl md:text-7xl text-title-primary leading-[0.85] tracking-[-0.04em] mb-8"
         >
            Catálogo
         </h1>
         <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {
               productsWithSlug.map((product) => (
                  <li class="group relative flex flex-col bg-white overflow-hidden rounded-xl">
                     <div class="relative overflow-hidden aspect-square">
                        <button
                           class="absolute top-3 right-3 z-20 p-2 bg-white backdrop-blur-sm rounded-full shadow-sm hover:scale-110 transition-transform duration-300 text-text-base hover:cursor-pointer"
                           aria-label="Agregar a favoritos"
                        >
                           <Like class="size-6" />
                        </button>

                        <a
                           href={`/catalogo/${product.generatedSlug}`}
                           class="block w-full h-full"
                        >
                           <img
                              src={product.imageUrl}
                              alt={product.title}
                              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                           />
                           <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                        </a>
                     </div>

                     <div class="pt-6 pb-2 flex flex-col flex-grow">
                        <a
                           href={`/catalogo/${product.generatedSlug}`}
                           class="flex-grow"
                        >
                           <p class="text-xs uppercase tracking-[0.2em] opacity-95 mb-2">
                              {product.category}
                           </p>
                           <div class="flex justify-between items-start">
                              <h2 class="text-lg font-medium leading-tight text-neutral-800">
                                 {product.title}
                              </h2>
                              <p class="text-lg font-semibold text-neutral-900">
                                 ${product.price}
                              </p>
                           </div>
                        </a>

                        <button
                           onclick={`window.open('https://wa.me/TUNUMERO?text=Hola! Consulto disponibilidad de: ${product.title}', '_blank')`}
                           class="mt-4 w-full py-3 px-4 bg-cta text-white text-xs font-bold uppercase tracking-widest rounded-lg 
             hover:cursor-pointer
             hover:bg-cta/95 transition active:scale-[0.98]"
                        >
                           Consultar Disponibilidad
                        </button>
                     </div>
                  </li>
               ))
            }
         </ul>
      </SectionContainer>
   </main>
</Layout>
